# =============================================================================
# GreenAudit — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# NE COMMITEZ JAMAIS le fichier .env — seul .env.example va dans git.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données PostgreSQL (obligatoire)
# Exemple Railway : postgresql+asyncpg://postgres:xxx@containers-us-west-xxx.railway.app:5432/railway
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# -----------------------------------------------------------------------------
# JWT — Clé de signature des tokens (obligatoire, min 32 caractères)
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=REMPLACER_PAR_UNE_CLE_ALEATOIRE_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# CORS — URLs frontend autorisées (séparées par des virgules)
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://green-audit.fr,https://www.green-audit.fr

# -----------------------------------------------------------------------------
# Stockage PDFs générés (chemin relatif ou absolu)
# -----------------------------------------------------------------------------
PDF_STORAGE_PATH=./reports

# -----------------------------------------------------------------------------
# Frontend URL (utilisé pour les redirections Stripe)
# -----------------------------------------------------------------------------
FRONTEND_URL=https://green-audit.fr

# -----------------------------------------------------------------------------
# Stripe (obligatoire pour les paiements Pro)
# Clés disponibles sur https://dashboard.stripe.com/apikeys
# Webhook secret : https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRO_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Claude / Anthropic API (obligatoire pour le monitoring continu + scan IA)
# Clé disponible sur https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Super admin (email qui reçoit automatiquement le flag is_superadmin)
# -----------------------------------------------------------------------------
SUPERADMIN_EMAIL=votre@email.com

# -----------------------------------------------------------------------------
# SMTP (formulaire de contact — optionnel)
# Utiliser un App Password Gmail : https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=APP_PASSWORD_GMAIL_16_CHARS

# -----------------------------------------------------------------------------
# Sentry (monitoring d'erreurs — optionnel mais recommandé en prod)
# DSN disponible sur https://sentry.io → Projet → Settings → Client Keys
# -----------------------------------------------------------------------------
SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX
